# =============================================================================
# OFAC Scanner Service - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ofac:ofac@localhost:5432/ofac

# -----------------------------------------------------------------------------
# API Security
# -----------------------------------------------------------------------------
# Leave empty for development (no auth required)
# Set a strong random value for production
OFAC_API_KEY=

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# Default allows OpenBB Workspace
CORS_ORIGINS=https://pro.openbb.co,http://localhost:3000

# -----------------------------------------------------------------------------
# Polling Configuration
# -----------------------------------------------------------------------------
# How often to poll OFAC pages (in minutes)
POLL_INTERVAL_MINUTES=15

# Maximum retries on failed poll
POLL_MAX_RETRIES=3

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=false

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable the background polling scheduler
ENABLE_SCHEDULER=true
